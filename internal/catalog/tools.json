{
  "protocolVersion": "2.0",
  "tools": [
    {
      "mcpName": "create_task",
      "action": "task.create",
      "description": "Create a new task in Super Productivity",
      "inputSchema": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "notes": { "type": "string" },
          "projectId": { "type": "string" },
          "parentId": { "type": "string" },
          "timeEstimate": { "type": "integer", "minimum": 0 },
          "tagIds": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["title"]
      }
    },
    {
      "mcpName": "get_tasks",
      "action": "task.list",
      "description": "List tasks from Super Productivity",
      "inputSchema": {
        "type": "object",
        "properties": {
          "includeDone": { "type": "boolean" }
        }
      }
    },
    {
      "mcpName": "get_task",
      "action": "task.get",
      "description": "Get a specific task by ID",
      "inputSchema": {
        "type": "object",
        "properties": {
          "taskId": { "type": "string" }
        },
        "required": ["taskId"]
      }
    },
    {
      "mcpName": "update_task",
      "action": "task.update",
      "description": "Update an existing task",
      "inputSchema": {
        "type": "object",
        "properties": {
          "taskId": { "type": "string" },
          "title": { "type": "string" },
          "notes": { "type": "string" },
          "projectId": { "type": "string" },
          "tagIds": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["taskId"]
      }
    },
    {
      "mcpName": "complete_task",
      "action": "task.complete",
      "description": "Mark a task as done",
      "inputSchema": {
        "type": "object",
        "properties": { "taskId": { "type": "string" } },
        "required": ["taskId"]
      }
    },
    {
      "mcpName": "uncomplete_task",
      "action": "task.uncomplete",
      "description": "Unmark a task as done",
      "inputSchema": {
        "type": "object",
        "properties": { "taskId": { "type": "string" } },
        "required": ["taskId"]
      }
    },
    {
      "mcpName": "archive_task",
      "action": "task.archive",
      "description": "Archive a task",
      "inputSchema": {
        "type": "object",
        "properties": { "taskId": { "type": "string" } },
        "required": ["taskId"]
      }
    },
    {
      "mcpName": "add_time_to_task",
      "action": "task.addTime",
      "description": "Add tracked time to a task (timeMs is duration in milliseconds)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "taskId": { "type": "string" },
          "timeMs": { "type": "integer", "minimum": 0 }
        },
        "required": ["taskId", "timeMs"]
      }
    },
    {
      "mcpName": "reorder_task",
      "action": "task.reorder",
      "description": "Reorder tasks within a project or tag context",
      "inputSchema": {
        "type": "object",
        "properties": {
          "taskIds": { "type": "array", "items": { "type": "string" } },
          "contextId": { "type": "string" },
          "contextType": { "type": "string", "enum": ["project", "tag"] }
        },
        "required": ["taskIds"]
      }
    },
    {
      "mcpName": "get_projects",
      "action": "project.list",
      "description": "List all projects",
      "inputSchema": { "type": "object" }
    },
    {
      "mcpName": "create_project",
      "action": "project.create",
      "description": "Create a new project",
      "inputSchema": {
        "type": "object",
        "properties": { "title": { "type": "string" } },
        "required": ["title"]
      }
    },
    {
      "mcpName": "update_project",
      "action": "project.update",
      "description": "Update an existing project",
      "inputSchema": {
        "type": "object",
        "properties": {
          "projectId": { "type": "string" },
          "data": { "type": "object" }
        },
        "required": ["projectId"]
      }
    },
    {
      "mcpName": "get_tags",
      "action": "tag.list",
      "description": "List all tags",
      "inputSchema": { "type": "object" }
    },
    {
      "mcpName": "create_tag",
      "action": "tag.create",
      "description": "Create a new tag",
      "inputSchema": {
        "type": "object",
        "properties": { "title": { "type": "string" } },
        "required": ["title"]
      }
    },
    {
      "mcpName": "update_tag",
      "action": "tag.update",
      "description": "Update an existing tag",
      "inputSchema": {
        "type": "object",
        "properties": {
          "tagId": { "type": "string" },
          "data": { "type": "object" }
        },
        "required": ["tagId"]
      }
    },
    {
      "mcpName": "show_notification",
      "action": "notification.show",
      "description": "Show a notification in Super Productivity",
      "inputSchema": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["SUCCESS", "INFO", "WARNING", "ERROR"]
          }
        },
        "required": ["message"]
      }
    },
    {
      "mcpName": "bridge_health",
      "action": "bridge.health",
      "description": "Check if the SP plugin bridge is healthy and responding",
      "inputSchema": { "type": "object" }
    },
    {
      "mcpName": "bridge_capabilities",
      "action": "bridge.capabilities",
      "description": "Get the SP plugin bridge capabilities and supported actions",
      "inputSchema": { "type": "object" }
    }
  ]
}
